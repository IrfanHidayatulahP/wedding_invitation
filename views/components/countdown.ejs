<section class="countdown-section">
    <div class="countdown-bg-image"></div>
    <div class="countdown-overlay"></div>

    <div class="countdown-content">
        <h2 class="countdown-title">ALMOST TIME FOR OUR CELEBRATION</h2>

        <div class="timer-grid">
            <div class="timer-item">
                <span id="days" class="timer-number">00</span>
                <span class="timer-label">DAYS</span>
            </div>
            <div class="timer-item">
                <span id="hours" class="timer-number">00</span>
                <span class="timer-label">HOURS</span>
            </div>
            <div class="timer-item">
                <span id="minutes" class="timer-number">00</span>
                <span class="timer-label">MINUTES</span>
            </div>
            <div class="timer-item">
                <span id="seconds" class="timer-number">00</span>
                <span class="timer-label">SECONDS</span>
            </div>
        </div>

        <div class="action-container">
            <a href="https://www.google.com/calendar/render?action=TEMPLATE&text=Wedding+of+Rizky+%26+Ceria&dates=20260523T000000Z/20260523T070000Z&details=Selamat+datang+di+pernikahan+kami!&location=Desa+Pauh+Menang,+Kec.+Pamenang,+Kab.+Merangin,+Jambi&sf=true&output=xml"
                target="_blank" class="save-date-btn">
                &rarr; SAVE THE DATE
            </a>
        </div>
    </div>
</section>

<script>
    // Gunakan format ISO agar lebih kompatibel di semua browser (Safari/Chrome/HP)
    const weddingDate = new Date("2026-05-23T07:00:00").getTime();

    const countdownTimer = setInterval(function () {
        const now = new Date().getTime();
        const distance = weddingDate - now;

        const d = Math.floor(distance / (1000 * 60 * 60 * 24));
        const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((distance % (1000 * 60)) / 1000);

        // Update UI
        document.getElementById("days").innerHTML = d.toString().padStart(2, '0');
        document.getElementById("hours").innerHTML = h.toString().padStart(2, '0');
        document.getElementById("minutes").innerHTML = m.toString().padStart(2, '0');
        document.getElementById("seconds").innerHTML = s.toString().padStart(2, '0');

        if (distance < 0) {
            clearInterval(countdownTimer);
            document.querySelector(".timer-grid").innerHTML = "<h3 class='event-started'>HARI BAHAGIA TELAH TIBA</h3>";
        }
    }, 1000);
</script>