<div class="wishes-section">
    <div class="section-header">
        <h2 class="section-title">WISHES</h2>
        <p class="wishes-desc">
            Give your prayers and wishes for the bride and groom to build a happy and lasting family.
        </p>
    </div>

    <div class="wishes-form-container">
        <form id="wishesForm" class="wishes-form">
            <input type="text" name="name" placeholder="Name" class="wish-input" required>
            <textarea name="message" placeholder="Your Wishes" class="wish-textarea" rows="4" required></textarea>
            <button type="submit" class="send-btn">SEND WISHES</button>
        </form>
    </div>

    <div class="wishes-display">
        <div class="wish-item">
            <h4 class="wish-name">Sahabat Imam</h4>
            <p class="wish-text">Selamat menempuh hidup baru Imam & Nandira! Semoga menjadi keluarga yang sakinah
                mawaddah warahmah. Bahagia selamanya!</p>
        </div>

        <div class="wish-item">
            <h4 class="wish-name">Keluarga Besar</h4>
            <p class="wish-text">Barakallahu lakum wa baraka alaikum. Semoga lancar sampai hari H dan diberkahi setiap
                langkahnya.</p>
        </div>
    </div>
</div>