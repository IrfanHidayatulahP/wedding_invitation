<!-- views/components/wishes-input.ejs -->
<section class="wishes-section wishes-input-page">
    <div class="wishes-bg-image"></div>
    <div class="wishes-overlay"></div>

    <div class="wishes-content">
        <div class="section-header">
            <h2 class="section-title">GIVE A WISH</h2>
            <p class="wishes-desc">
                Berikan doa dan ucapan terbaik Anda untuk Imam & Nandira agar menjadi keluarga yang bahagia dan
                langgeng.
            </p>
        </div>

        <div class="wishes-form-container">
            <form id="wishesForm" class="wishes-form">
                <input type="text" name="name" placeholder="Nama Anda" class="wish-input" required>
                <textarea name="message" placeholder="Tulis Ucapan & Doa..." class="wish-textarea" rows="4"
                    required></textarea>
                <button type="submit" class="send-btn">KIRIM UCAPAN</button>
            </form>
        </div>
    </div>
</section>