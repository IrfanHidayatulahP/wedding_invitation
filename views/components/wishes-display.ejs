<section class="wishes-section wishes-display-page">
    <div class="wishes-bg-image"></div>
    <div class="wishes-overlay"></div>

    <div class="wishes-content">
        <div class="section-header">
            <h2 class="section-title">WISHES GALLERY</h2>
        </div>

        <div class="wishes-slider" id="wishesSlider">
            <% if (wishes && wishes.length> 0) {
                // Kita bagi array wishes menjadi kelompok berisi 3 ucapan per slide
                const perSlide = 4;
                for (let i = 0; i < wishes.length; i +=perSlide) { const chunk=wishes.slice(i, i + perSlide); %>
                    <div class="wishes-slide">
                        <div class="wishes-grid">
                            <% chunk.forEach(wish=> { %>
                                <div class="wish-item">
                                    <h4 class="wish-name">
                                        <%= wish.name %>
                                    </h4>
                                    <p class="wish-text">
                                        <%= wish.message %>
                                    </p>
                                </div>
                                <% }) %>
                        </div>
                        <% if (i + perSlide < wishes.length) { %>
                            <div class="scroll-hint">Swipe for more →</div>
                            <% } %>
                    </div>
                    <% } } else { %>
                        <div class="wishes-slide">
                            <p class="wish-text" style="text-align: center; width: 100%;">There are no wishes yet. Be
                                the first!</p>
                        </div>
                        <% } %>
        </div>
    </div>
</section>