<!-- views/components/video-playback.ejs -->
<section class="video-section">
    <div class="split-layout">

        <!-- Sisi Kanan: Konten Video -->
        <div class="split-right">
            <div class="split-bg-image" style="background-image: url('/images/SLM09319.JPG');"></div>
            <div class="split-overlay-dark"></div>

            <div class="video-content-wrapper">
                <div class="video-header">
                    <p class="video-subtitle">UNVEILING</p>
                    <h2 class="video-title">OUR PREWEDDING STORY</h2>
                </div>

                <div class="video-player-container" id="videoContainer" onclick="toggleVideo()">
                    <video id="prewedVideo" class="content-video" playsinline webkit-playsinline muted>
                        <source src="/videos/202605120434.mp4" type="video/mp4">
                    </video>

                    <div class="video-controls-overlay" id="videoControls">
                        <div class="play-pause-btn" id="mainBtn">
                            <svg id="playIcon" viewBox="0 0 24 24" fill="currentColor" class="icon-svg">
                                <path d="M8 5v14l11-7z" />
                            </svg>
                            <svg id="pauseIcon" viewBox="0 0 24 24" fill="currentColor" class="icon-svg hidden">
                                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="video-quote-box">
                    <p class="handwriting-text">
                        Every love story is beautiful, but ours is my favorite.
                        Through the highs and lows, our love grows stronger.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    {
        const video = document.getElementById('prewedVideo');
        const controls = document.getElementById('videoControls');
        const videoContainer = document.getElementById('videoContainer');
        const playIcon = document.getElementById('playIcon');
        const pauseIcon = document.getElementById('pauseIcon');

        let hideTimeout;

        window.toggleVideo = function () {
            if (video.paused) {
                video.play();
            } else {
                video.pause();
            }
        }

        function hideControls() {
            if (!video.paused) {
                controls.classList.add('is-hidden');
            }
        }

        function showControlsWithTimer() {
            // Paksa tampilkan dulu
            controls.classList.remove('is-hidden');
            clearTimeout(hideTimeout);

            // Timer untuk menyembunyikan
            hideTimeout = setTimeout(hideControls, 3000);
        }

        function updateUI(isPlaying) {
            if (isPlaying) {
                playIcon.classList.add('hidden');
                pauseIcon.classList.remove('hidden');
                showControlsWithTimer();
            } else {
                playIcon.classList.remove('hidden');
                pauseIcon.classList.add('hidden');
                controls.classList.remove('is-hidden');
                clearTimeout(hideTimeout);
            }
        }

        // LISTENER KHUSUS MOBILE & SAFARI
        // Gunakan 'click' pada container karena Safari terkadang memblokir touchstart jika bentrok dengan playsinline
        videoContainer.addEventListener('click', function () {
            showControlsWithTimer();
        });
        videoContainer.addEventListener('touchend', showControlsWithTimer);

        // Gunakan event 'playing' untuk Safari: terpicu saat video BENAR-BENAR mulai bergerak
        video.addEventListener('playing', () => updateUI(true));
        video.addEventListener('pause', () => updateUI(false));
        video.addEventListener('waiting', () => {
            controls.classList.remove('is-hidden');
            clearTimeout(hideTimeout);
        });

        video.onended = () => updateUI(false);
    }
</script>