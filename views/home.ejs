<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wedding Invitation - CERIA & RIZKY</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;600&family=Cormorant+Garamond:wght@300;400&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/splash.css">
    <link rel="stylesheet" href="/css/left-panel.css">
    <link rel="stylesheet" href="/css/menu.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/couple.css">
    <link rel="stylesheet" href="/css/story.css">
    <link rel="stylesheet" href="/css/event.css">
    <link rel="stylesheet" href="/css/gallery.css">
    <link rel="stylesheet" href="/css/features.css">
    <link rel="stylesheet" href="/css/closing.css">
    <link rel="stylesheet" href="/css/hero.css">
    <link rel="stylesheet" href="/css/welcome.css">
    <link rel="stylesheet" href="/css/opened-content.css">
    <link rel="stylesheet" href="/css/wishes.css">
    <link rel="stylesheet" href="/css/gift.css">
    <link rel="stylesheet" href="/css/countdown.css">
    <link rel="stylesheet" href="/css/video.css">
</head>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html,
    body {
        height: 100%;
        width: 100%;
        overflow: hidden;
    }

    /* Saat terbuka, izinkan scroll hanya jika konten melebih tinggi layar */
    body.is-unlocked {
        overflow-y: auto;
    }
</style>

<body class="min-h-screen overflow-hidden bg-[#0b0b0b]">

    <%- include('partials/splash') %>

        <%- include('components/menu') %>

            <main id="mainContent" class="grid grid-cols-1 lg:grid-cols-[69.5fr_30.5fr] p-0 m-0">
                <div class="hidden lg:block">
                    <%- include('partials/left-panel') %>
                </div>

                <%- include('partials/right-panel') %>
            </main>

            <audio id="bgMusic" loop>
                <source src="/music/If you love me for me (Barbie)  Karaoke  Instrumental  DUET Sing along.mp3"
                    type="audio/mpeg">
                Browser Anda tidak mendukung elemen audio.
            </audio>

            <script>
                const openBtn = document.getElementById('openBtn');
                const mainContent = document.getElementById('mainContent');
                const menuIcon = document.getElementById('menuIcon');
                const menuOverlay = document.getElementById('menuOverlay');
                const closeMenu = document.getElementById('closeMenu');
                const menuBackdrop = document.querySelector('.menu-backdrop');
                const bgMusic = document.getElementById('bgMusic');

                let isMusicStarted = false;

                // Klik LET'S OPEN
                if (openBtn) {
                    openBtn.addEventListener('click', () => {
                        if (bgMusic) {
                            // Safari butuh interaksi user yang jelas untuk memulai audio
                            const playPromise = bgMusic.play();

                            if (playPromise !== undefined) {
                                playPromise.then(() => {
                                    isMusicStarted = true;
                                }).catch(error => {
                                    console.log("Safari auto-play ditahan:", error);
                                });
                            }
                        }

                        document.body.classList.add('is-unlocked');
                        document.getElementById('mainContent').classList.add('is-opened');

                        setTimeout(() => {
                            const welcomeSection = document.querySelector('.content-wrapper');
                            if (welcomeSection) {
                                welcomeSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                            }
                        }, 50);
                    });
                }

                // Penanganan Visibility API yang Responsif untuk Safari
                const handleVisibilityChange = () => {
                    if (!bgMusic || !isMusicStarted) return;

                    if (document.hidden || document.webkitHidden) {
                        // Gunakan webkitHidden untuk kompatibilitas Safari lama
                        bgMusic.pause();
                    } else {
                        // Saat kembali ke tab, pastikan hanya play jika user sudah klik "Let's Open"
                        if (document.body.classList.contains('is-unlocked')) {
                            const playPromise = bgMusic.play();
                            if (playPromise !== undefined) {
                                playPromise.catch(() => {
                                    // Jika Safari memblokir resume otomatis (kebijakan low power mode)
                                    console.log("Resume audio diblokir Safari");
                                });
                            }
                        }
                    }
                };

                // Tambahkan listener untuk berbagai prefix browser
                document.addEventListener("visibilitychange", handleVisibilityChange);
                document.addEventListener("webkitvisibilitychange", handleVisibilityChange);

                // Tambahan untuk Safari iOS: Pause jika user meminimalkan browser (menekan tombol home)
                window.addEventListener('pagehide', () => {
                    if (bgMusic) bgMusic.pause();
                });

                window.addEventListener('pageshow', () => {
                    if (bgMusic && isMusicStarted && document.body.classList.contains('is-unlocked')) {
                        bgMusic.play();
                    }
                });

            </script>

            <script src="/js/menu.js"></script>

            <script src="/js/splash.js"></script>

            <script src="https://unpkg.com/taos@1.0.5/dist/taos.js"></script>
</body>

</html>