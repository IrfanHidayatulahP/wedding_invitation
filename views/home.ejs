<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wedding Invitation - Imam & Nandira</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;600&family=Cormorant+Garamond:wght@300;400&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/splash.css">
    <link rel="stylesheet" href="/css/left-panel.css">
    <link rel="stylesheet" href="/css/menu.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/couple.css">
    <link rel="stylesheet" href="/css/story.css">
    <link rel="stylesheet" href="/css/event.css">
    <link rel="stylesheet" href="/css/gallery.css">
    <link rel="stylesheet" href="/css/features.css">
    <link rel="stylesheet" href="/css/closing.css">
    <link rel="stylesheet" href="/css/hero.css">
    <link rel="stylesheet" href="/css/welcome.css">
    <link rel="stylesheet" href="/css/opened-content.css">
    <link rel="stylesheet" href="/css/wishes.css">
    <link rel="stylesheet" href="/css/gift.css">
    <link rel="stylesheet" href="/css/countdown.css">
    <link rel="stylesheet" href="/css/video.css">
</head>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html,
    body {
        height: 100%;
        width: 100%;
        overflow: hidden;
        /* Kunci scroll global di awal */
    }

    /* Saat terbuka, izinkan scroll hanya jika konten melebih tinggi layar */
    body.is-unlocked {
        overflow-y: auto;
    }
</style>

<body class="min-h-screen overflow-hidden bg-[#0b0b0b]">

    <%- include('partials/splash') %>

        <%- include('components/menu') %>

            <main id="mainContent" class="grid grid-cols-1 lg:grid-cols-[69.5fr_30.5fr] p-0 m-0">
                <div class="hidden lg:block">
                    <%- include('partials/left-panel') %>
                </div>

                <%- include('partials/right-panel') %>
            </main>

            <script>
                const openBtn = document.getElementById('openBtn');
                const mainContent = document.getElementById('mainContent');
                const menuIcon = document.getElementById('menuIcon');
                const menuOverlay = document.getElementById('menuOverlay');
                const closeMenu = document.getElementById('closeMenu');
                const menuBackdrop = document.querySelector('.menu-backdrop');

                // Klik LET'S OPEN
                if (openBtn) {
                    openBtn.addEventListener('click', () => {
                        // 1. Tambahkan class ke body (Pemicu utama untuk Menu & Scroll)
                        document.body.classList.add('is-unlocked');

                        // 2. Tambahkan class ke mainContent (Untuk layout grid/panel)
                        mainContent.classList.add('is-opened');

                        // 3. Smooth Scroll ke konten utama
                        // Kita beri delay sedikit agar browser selesai merender layout baru
                        setTimeout(() => {
                            const welcomeSection = document.querySelector('.content-wrapper');
                            if (welcomeSection) {
                                welcomeSection.scrollIntoView({
                                    behavior: 'smooth',
                                    block: 'start'
                                });
                            }
                        }, 50);
                    });
                }

            </script>

            <script src="/js/menu.js"></script>

            <script src="/js/splash.js"></script>

            <script src="https://unpkg.com/taos@1.0.5/dist/taos.js"></script>
</body>

</html>